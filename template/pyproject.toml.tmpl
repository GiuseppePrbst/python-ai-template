[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{DISTRIBUTION_NAME}}"
version = "0.1.0"
description = "A minimal, maintainable Python project."
readme = "README.md"
requires-python = ">=3.12"

[dependency-groups]
dev = [
    "pyright",
    "pytest",
    "ruff",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{PACKAGE_NAME}}"]

[tool.ruff]
target-version = "py312"
line-length = 88

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]

[tool.pyright]
include = ["src", "tests"]
pythonVersion = "3.12"
typeCheckingMode = "strict"

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-ra"
